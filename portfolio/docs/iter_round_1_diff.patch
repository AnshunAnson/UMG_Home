+        {/* 填充六边形 */}
+        <motion.path
+          d={hexPath(size)}
+          fill={`url(#grad-${index})`}
+          initial={{ opacity: 0 }}
+          animate={{ opacity: isActive ? 1 : 0.5 }}
+          transition={{ duration: 0.3 }}
+        />
+
+        {/* 进度环 */}
