+  // 根据等级计算大小
+  const baseSize = 120;
+  const sizeMultiplier = 0.8 + (skill.level / 100) * 0.4;
+  const size = baseSize * sizeMultiplier;
+
+  // 计算六边形路径
+  const hexPath = (s: number) => {
