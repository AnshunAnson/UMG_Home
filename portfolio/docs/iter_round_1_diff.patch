+// 六边形技能卡片组件
+function HexagonSkill({
+  skill,
+  index,
+  isActive,
+  onHover,
+  onLeave,
+}: {
+  skill: typeof skillsData[0];
+  index: number;
+  isActive: boolean;
+  onHover: () => void;
+  onLeave: () => void;
