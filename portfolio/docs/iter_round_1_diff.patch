+            <stop offset="100%" stopColor="#00d4aa" stopOpacity={isActive ? 0.1 : 0.05} />
+          </linearGradient>
+        </defs>
+
+        {/* 边框六边形 */}
+        <motion.path
+          d={hexPath(size)}
+          fill="none"
+          stroke="#00d4aa"
+          strokeWidth={isActive ? 2 : 1}
+          opacity={isActive ? 1 : 0.5}
+          filter={isActive ? `url(#glow-${index})` : undefined}
+          initial={{ pathLength: 0 }}
+          animate={isInView ? { pathLength: 1 } : {}}
